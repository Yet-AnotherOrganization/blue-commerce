generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  name      String
  nameSlug  String?       @unique
  password  String
  phone     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  status    AccountStatus @default(DISABLED)
  avatar    String?
  role      Role          @default(USER)
  cart      Cart?
  favorites Favorite[]
  orders    Order[]
  reviews   Review[]
  store     Store?

  stripeCustomerId String? @unique
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User?      @relation(fields: [userId], references: [id])
  items     CartItem[]
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  quantity  Int     @default(1)
  metadata  Json?
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

model Store {
  id        String      @id @default(cuid())
  storeName String
  nameSlug  String?     @unique
  ownerId   String      @unique
  avatar    String?
  products  Product[]
  owner     User?       @relation(fields: [ownerId], references: [id])
  status    StoreStatus @default(DISABLED)
}

model Order {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  ownerId   String
  status    OrderStatus @default(PENDING)
  owner     User        @relation(fields: [ownerId], references: [id])
  items     OrderItem[]

  stripeSessionId String? @unique
  totalAmount Int
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  price     Decimal
  quantity  Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade) 
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Product {
  id          String        @id @default(cuid())
  status      ProductStatus @default(DRAFT)
  name        String
  nameSlug    String?       @unique
  description String
  price       Decimal
  imageUrl    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  categoryId  String
  stock       Int
  sellerId    String
  carts       CartItem[]
  favoritedBy Favorite[]
  orderItems  OrderItem[]
  category    Category      @relation(fields: [categoryId], references: [id])
  seller      Store         @relation(fields: [sellerId], references: [id])
  reviews     Review[]
}

model Category {
  id          String    @id @default(uuid())
  name        String
  nameSlug    String?   @unique
  description String
  imageUrl    String?
  products    Product[]
}

model Review {
  id        String  @id @default(cuid())
  rating    Int
  text      String
  ownerId   String
  productId String
  owner     User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([ownerId, productId])
}

model Favorite {
  id        String  @id @default(cuid())
  ownerId   String
  productId String
  owner     User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  item      Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([ownerId, productId])
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum AccountStatus {
  ENABLED
  DISABLED
}

enum Role {
  ADMIN
  USER
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum StoreStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}
