generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  name      String?
  password  String
  phone     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  orders    Order[]
  reviews   Review[]
  status    AccountStatus @default(DISABLED)
  avatar    String?
  role      Role          @default(USER)
  store     Store?
  cart      Cart?
}

model Cart {
  id String @id @default(cuid())

  // whose cart is this?
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  // what does it hold?
  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id String @id @default(cuid())

  // in which cart?
  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id])

  // what item?
  productId String
  product   Product @relation(fields: [productId], references: [id])

  // how many?
  quantity Int @default(1)

  // one item per cart (the rest go to quantity)
  @@unique([cartId, productId])
}

model Store {
  id        String    @id @default(cuid())
  storeName String
  ownerId   String    @unique
  owner     User      @relation(fields: [ownerId], references: [id])
  products  Product[]
  avatar    String?
}

model Order {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  items     OrderItem[]
  ownerId   String
  owner     User        @relation(fields: [ownerId], references: [id])
  status    OrderStatus @default(PENDING)
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  price    Decimal
  quantity Int
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String
  price       Decimal
  imageUrl    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  reviews     Review[]
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  stock       Int
  sellerId    String
  seller      Store       @relation(fields: [sellerId], references: [id])
  carts       CartItem[]
}

model Category {
  id          String    @id @default(uuid())
  name        String
  description String
  imageUrl    String?
  products    Product[]
}

model Review {
  id        String  @id @default(cuid())
  rating    Int
  text      String
  ownerId   String
  owner     User    @relation(fields: [ownerId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@unique([ownerId, productId]) // 1 kullanıcı 1 ürüne yalnız 1 Review atabilir.
}

// Sipariş durumlarını standartlaştırmak için Enum
enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum AccountStatus {
  ENABLED
  DISABLED
}

enum Role {
  ADMIN
  USER
}
